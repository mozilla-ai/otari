# Local gateway development environment variables

# Required for management endpoints
OTARI_MASTER_KEY=replace-with-a-secure-random-value

# Optional overrides
# OTARI_DATABASE_URL=postgresql://gateway:gateway@localhost:5432/gateway
OTARI_HOST=0.0.0.0
OTARI_PORT=8000
OTARI_AUTO_MIGRATE=true
OTARI_BOOTSTRAP_API_KEY=true

# Provider credentials used directly by gateway/provider clients
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=

# Web-search backend (optional). Point the gateway at a SearXNG-compatible
# /search?format=json service. The bundled `web-search-tavily` /
# `web-search-brave` compose profiles front a licensed API; the key lives in
# the adapter container, not the gateway.
# GATEWAY_WEB_SEARCH_URL=http://tavily-adapter:8080
# TAVILY_API_KEY=
# BRAVE_API_KEY=
