# Local gateway development environment variables

# Required for management endpoints
GATEWAY_MASTER_KEY=replace-with-a-secure-random-value

# Optional overrides
# GATEWAY_DATABASE_URL=postgresql://gateway:gateway@localhost:5432/gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_AUTO_MIGRATE=true
GATEWAY_BOOTSTRAP_API_KEY=true

# Provider credentials used directly by gateway/provider clients
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=
