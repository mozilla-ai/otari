# Copy to `.env` (gitignored) and fill in provider keys only if you want
# the demo to make real provider calls. The management and dry-run parts do
# not spend tokens.

# Host-side gateway port. Override if 8000 is already taken.
OTARI_PORT=8090

# Host-side postgres port. Override if 5432 is already taken.
GATEWAY_POSTGRES_PORT=5434

# Gateway config file mounted by docker-compose.
GATEWAY_CONFIG_PATH=./demo/routing-gateway/gateway-config.yml

# Local demo master key. Must match gateway-config.yml.
GATEWAY_KEY=demo-master-key

# Optional. Defaults to http://localhost:$OTARI_PORT.
# GATEWAY_URL=http://localhost:8090

# Optional provider keys. Required only when RUN_PROVIDER_CALL=1.
# OPENAI_API_KEY=sk-REPLACE_ME
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Set to 1 to send one real /v1/chat/completions request through
# model: default_routing and then inspect route traces.
RUN_PROVIDER_CALL=0
