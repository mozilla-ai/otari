# Copy to `.env` (gitignored) and fill in your real keys.
# `./start.sh` and `./stop.sh` load this when invoking docker-compose.

# Optional frontier key, used only for the Act-1/Act-3 frontier contrast.
# The core open-weights story (Acts 1-3) runs on a local llamafile and needs
# no key at all.
# OPENAI_API_KEY=sk-REPLACE_ME
# Frontier model used for the Act-1 contrast (OpenAI Responses API + native
# web_search / shell tools). Defaults to gpt-5.5.
# OPENAI_MODEL=gpt-5.5

# Where the gateway should reach a local llamafile (the open-weights model for
# Acts 1-3). Defaults to host.docker.internal:8080 so a llamafile running on
# the macOS/Windows host is reachable from the gateway container.
# LLAMAFILE_API_BASE=http://host.docker.internal:8080/v1

# Path to an executable *.llamafile. If set, demo_flow.sh auto-starts it on
# :8080 and shuts it down on exit. If unset and nothing is already serving on
# :8080, the demo prints a one-time download recipe.
# LLAMAFILE_BIN=/tmp/qwen3-4b.llamafile

# Host-side gateway port. Override if 8000 is already taken on your machine.
GATEWAY_PORT=8088

# Host-side postgres port. Override if 5432 is already taken.
GATEWAY_POSTGRES_PORT=5433

# Gateway config file the docker-compose mounts. Points at this folder's
# demo config so the repo's main config.yml stays operator-owned.
GATEWAY_CONFIG_PATH=./demo/board/gateway-config.yml

# ── Act 4: platform mode (Otari.ai) ────────────────────────────────────────
# Platform mode uses TWO Otari.ai tokens:
#   OTARI_AI_TOKEN   — the GATEWAY's token (server-to-server, X-Gateway-Token).
#                      When set + started via ./start-platform.sh, the gateway
#                      delegates to Otari.ai and reaches managed providers like
#                      Mozilla.ai Inference with no provider keys of its own.
#   OTARI_USER_TOKEN — the per-request CLIENT bearer (X-User-Token): a project/
#                      API token from Otari.ai that authorizes spend and selects
#                      the provider credential. Required to call the mzai model.
# OTARI_AI_TOKEN=otari_REPLACE_ME
# OTARI_USER_TOKEN=otari_REPLACE_ME
# Where the gateway reaches the platform. LOCAL platform (repo-root
# docker-compose, nginx on host :8100): use host.docker.internal — the default
# in docker-compose.platform.yml already does this, so you usually leave this
# unset. HOSTED platform: set to https://api.otari.ai/api/v1 (or leave unset to
# use that default). NEVER use localhost here — inside the gateway container
# that points at the container itself, not your host.
# PLATFORM_BASE_URL=http://host.docker.internal:8100/api/v1
# The stronger managed model to run Act 4 against, as provider:model. The model
# name must match what your org's Mozilla.ai Inference exposes.
# OTARI_MODEL=mzai:REPLACE_ME
