# Copy to `.env` (gitignored) and fill in your real keys.
# `./start.sh` and `./stop.sh` load this when invoking docker-compose.

# Your Anthropic API key. The gateway passes it to any-llm; SDKs pick it up.
# Required if you run the demo with --anthropic (the default).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Optional: required if you run the demo with --openai.
# OPENAI_API_KEY=sk-REPLACE_ME

# Optional: where the gateway should reach a local llamafile. Only consulted
# in --llamafile mode. Defaults to host.docker.internal:8080 so a llamafile
# running on the macOS/Windows host is reachable from the gateway container.
# LLAMAFILE_API_BASE=http://host.docker.internal:8080/v1

# Optional: use the Brave Search API instead of the bundled SearXNG metasearch.
# The free SearXNG engines rate-limit/CAPTCHA automated queries by IP, so
# Brave is the reliable choice. Get a key at https://brave.com/search/api/,
# uncomment both lines, then bring the stack up with the `web-search-brave`
# profile (see scripts/web-search-brave-adapter/README.md) instead of the
# default SearXNG `web-search` profile:
#   docker compose --env-file demo/web-search/.env \
#     --profile web-search-brave up -d --build brave-adapter otari
# BRAVE_API_KEY=brv-REPLACE_ME
# OTARI_WEB_SEARCH_URL=http://brave-adapter:8080

# Host-side gateway port. Override if 8000 is already taken on your machine.
OTARI_PORT=8088

# Host-side postgres port. Override if 5432 is already taken.
OTARI_POSTGRES_PORT=5433

# Gateway config file the docker-compose mounts. Points at this folder's
# demo config so the repo's main config.yml stays operator-owned.
OTARI_CONFIG_PATH=./demo/web-search/otari-config.yml
